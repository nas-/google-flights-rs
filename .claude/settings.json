{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git commit*)",
            "command": "cargo fmt && cargo clippy --all-targets -- -D warnings",
            "timeout": 120,
            "statusMessage": "cargo fmt + clippy..."
          }
        ]
      }
    ]
  }
}
